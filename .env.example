# Booking.com affiliate ID (aid). Optional — links work without it, but bookings
# won't be attributed to your affiliate account for commission.
# Get one from https://www.booking.com/affiliate-program/v2/index.html
NEXT_PUBLIC_BOOKING_AID=

# Map tiles. Optional — defaults to OpenStreetMap's public tiles, which are fine
# for development but not for production load. For real traffic, set these to a
# keyed provider (MapTiler, Stadia Maps, Carto — all have free tiers). Include
# your API key in the URL. Example (MapTiler):
#   NEXT_PUBLIC_MAP_TILE_URL=https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=YOUR_KEY
#   NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=&copy; MapTiler &copy; OpenStreetMap contributors
NEXT_PUBLIC_MAP_TILE_URL=
NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=
